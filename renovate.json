{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^1-idp-scaffolder/utils\\.py$/"
      ],
      "matchStrings": [
        "REMOTE_TEMPLATE_REPO = \"https://github\\.com/(?<depName>[^/]+/[^/@]+)@version=(?<currentValue>v[0-9.]+.*)\""
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.tf\\.jinja$/"
      ],
      "matchStrings": [
        "source\\s*=\\s*\"git::https://github\\.com/(?<depName>[^/]+/[^/]+?)\\.git//.*?\\?ref=(?<currentValue>v[0-9.]+.*)\""
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": ["github-tags"],
      "groupName": "IDP Template Version Updates"
    }
  ]
}
