name: CD Pipeline - Render & Push {{ app_name }}

on:
  push:
    branches:
      - main
    paths:
      - 'apps/{{ app_name }}/templated-manifests/**'

jobs:
  render:
    name: Render manifests
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Render the manifests
        run: |
          cd apps/{{ app_name }}

          # Convert GitHub repository path to lowercase for Docker registry compatibility
          IMAGE_REPO=$(echo "ghcr.io/{% raw %}${{ github.repository }}{% endraw %}/{{ team_name }}/{{ app_name }}" | tr '[:upper:]' '[:lower:]')

          # Render Helm chart overriding the image repository
          helm template {{ app_name }} templated-manifests \
            --set image.repository="$IMAGE_REPO" \
            --output-dir rendered-manifests

      # Implement blue-green deployment later https://github.com/argoproj/argocd-example-apps/tree/master/blue-green